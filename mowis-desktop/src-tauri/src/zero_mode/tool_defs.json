      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Workspace-relative path to delete."
        }
      },
      "required": ["path"]
    }
  },
  {
    "name": "move_file",
    "description": "Move or rename a file within the workspace.",
    "parameters": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
